# Stepwise — environment variables
#
# Ada, the in-app AI tutor, calls an LLM from a server-only route
# (app/api/tutor/route.ts) via OpenRouter. The key is read on the server only
# and is never sent to the browser. Copy this file to `.env.local`, add your
# key, and restart the dev server (env is loaded at startup):
#
#   cp .env.local.example .env.local

# Required. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional — defaults to tencent/hy3:free.
# Ada needs a TOOL-CAPABLE model to drive the canvas (jump steps, switch
# datasets, re-run on custom input). If a model can't tool-call, the route
# silently retries without tools and Ada degrades to explanation-only — she
# still teaches, but the visualization stops responding to her. If that
# happens, switch to a tool-capable slug here.
OPENROUTER_MODEL=tencent/hy3:free

# --- Rate limiting (optional) ---
# The tutor route rate-limits requests per IP to stop one user (or a loop) from
# draining the free tier. When these Upstash vars are UNSET it falls back to
# in-memory per-instance limiting — still enforced, but each serverless instance
# counts on its own, so it's weak in production. Set these before any public
# deploy for distributed limiting. Free Redis DB at https://console.upstash.com.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-rest-token

# Limit tuning (optional). Defaults: 10/min burst, 100/day. Override to tune from
# logs, or set a low value to exercise the 429 path in testing (e.g.
# RL_BURST_PER_MIN=2). A value of 0 blocks all AI traffic — a deliberate kill switch.
# RL_BURST_PER_MIN=10
# RL_DAILY_PER_DAY=100

# --- Database (Phase 4: sign-in, saved conversations, cross-device progress) ---
# Neon Postgres. Create a free project at https://console.neon.tech and copy the
# POOLED connection string (host contains "-pooler"). Keep sslmode=require.
# Server-only — never NEXT_PUBLIC_-prefix it.
# The app boots without this — /api/auth/get-session returns null rather than
# crashing — so you can run the visualizations unauthenticated. Sign-in, saved
# conversations, and cross-device progress all need it. `drizzle-kit generate`
# works offline; `db:migrate` / `db:push` do not.
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# --- Auth (Better Auth + GitHub OAuth) — wired and live ---
# Set all three plus DATABASE_URL above to enable sign-in. Without them the app
# still runs; the anonymous path is deliberately kept open.
# BETTER_AUTH_SECRET=   # generate with: openssl rand -base64 32   (>=32 chars)
# BETTER_AUTH_URL=http://localhost:3000
# Create a GitHub OAuth App (Settings → Developer settings → OAuth Apps → New).
# Authorization callback URL MUST be: {BETTER_AUTH_URL}/api/auth/callback/github
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
