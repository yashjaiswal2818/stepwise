# Stepwise — environment variables
#
# Ada, the in-app AI tutor, calls an LLM from a server-only route
# (app/api/tutor/route.ts). The key is read on the server only and is never
# sent to the browser. Copy this file to `.env.local`, add ONE provider's key,
# and restart the dev server (env is loaded at startup):
#
#   cp .env.local.example .env.local

# --- Option A: OpenRouter (used for testing; takes priority if set) ---
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here
# Optional — defaults to tencent/hy3:free. Any OpenRouter model slug works.
# (A tool-capable model is needed for Ada to *drive* the canvas; free/small
#  models still work for explanations, with tool-calling gracefully skipped.)
OPENROUTER_MODEL=tencent/hy3:free

# --- Option B: Anthropic (used only if OPENROUTER_API_KEY is unset) ---
# Get a key at https://console.anthropic.com  →  Settings  →  API Keys
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-opus-4-8
